{
  "name": "monkeyscloud/monkeyslegion-cli",
  "description": "Full-featured CLI framework for MonkeysLegion — code generation, migrations, environment tools, and interactive developer console.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "cli",
    "console",
    "artisan",
    "code-generation",
    "migration",
    "monkeyslegion"
  ],
  "authors": [
    {
      "name": "MonkeysCloud",
      "email": "jorge@monkeys.cloud"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.4",
    "ext-ctype": "*",
    "ext-readline": "*",
    "ext-pdo": "*",
    "nikic/php-parser": "^5.5",
    "doctrine/inflector": "^2.0",
    "monkeyscloud/monkeyslegion-core": "^2.0",
    "monkeyscloud/monkeyslegion-di": "^2.0",
    "monkeyscloud/monkeyslegion-entity": "^2.0",
    "monkeyscloud/monkeyslegion-database": "^2.0",
    "monkeyscloud/monkeyslegion-migration": "^2.0",
    "monkeyscloud/monkeyslegion-openapi": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Cli\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Cli\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/ml"
  ],
  "scripts": {
    "test": "phpunit"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev",
      "dev-2.x-dev": "2.0.x-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}